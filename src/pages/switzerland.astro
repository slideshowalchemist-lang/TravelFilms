---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Switzerland',
};
---

<Layout metadata={metadata}>

  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/Images/switzerland/switzerland_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Switzerland</h1>
      <p class="mt-4 text-lg opacity-90">
        Alpine peaks, pristine lakes, charming villages, efficient trains, chocolate, skiing, hiking, scenic beauty, tranquility
      </p>
    </div>
  </section>

  <section>Coming soon...</section>

</Layout>