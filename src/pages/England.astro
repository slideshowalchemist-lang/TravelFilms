---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'England',
};
---

<Layout metadata={metadata}>

  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/Images/england/england_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">England</h1>
      <p class="mt-4 text-lg opacity-90">
        London blends history, culture, iconic landmarks, vibrant neighbourhoods, global cuisine, and timeless architectural elegance
      </p>
    </div>
  </section>

  <section>Coming soon...</section>

</Layout>