---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Italy - Travel Chronicles Studio',
};
---

<Layout metadata={metadata}>

 <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">

    <div class="absolute inset-0">
      <img src="/Images/italy/italy_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Sicily</h1>
      <p class="mt-4 text-lg opacity-90">Timeless cities, Renaissance art, Roman ruins, rolling countryside, coastal villages, world-class cuisine, espresso culture, fashion, history, passion, beauty, unforgettable experiences</p>
    </div>

  </section>

  <!-- CONTENT -->
  <section>Coming soon...</section>

</Layout>