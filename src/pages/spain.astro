---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Spain - Travel Chronicles Studio',
};
---

<Layout metadata={metadata}>

  <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">

    <div class="absolute inset-0">
      <img 
        src="/Images/spain/spain.png" 
        class="w-full h-full object-cover"
        alt="Spain"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Spain</h1>
      <p class="mt-4 text-lg opacity-90">
        A journey through Andalusian heritage, Moorish architecture, and vibrant cities
      </p>
    </div>

  </section>

<!-- CONTENT SECTIONS -->


<!-- Spain Highlights-->
<section id="highlights" class="max-w-4xl mx-auto px-6 pt-5 pb-0">

  <h2 class="text-2xl font-bold mb-6">Highlights</h2>

  <div class="grid md:grid-cols-3 gap-6">

    <!-- Highlights 2024 -->
    <div
      onclick="openModal('/nX9M7OQOqmA')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/spain/spain.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Spain Highlights 2024"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Andalusia </span> Filmed on location, edited to showcase Andalusia’s beauty, architecture, atmosphere; a love letter featuring Seville, Granada, Córdoba, Málaga landmarks, culture, history [2024]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

</section>

<!-- Andalusia -->
<section id="malaga" class="max-w-4xl mx-auto px-6 pt-5 pb-0">

  <h2 class="text-2xl font-bold mb-6">Andalusia</h2>

  <div class="grid md:grid-cols-3 gap-6">

    <!-- Malaga-->
    <div
      onclick="openModal('/tbhW8itpvCk')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/spain/malaga.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Malaga"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Malaga </span> Málaga surprised us—Picasso’s legacy, Gibralfaro views, Alcazaba, cathedral, markets, cafés. A vibrant coastal city offering culture, history, and flavours beyond expectations for travellers exploring southern [2024]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

      <!-- Granada -->
    <div
      onclick="openModal('/9Ldu1UODtwU')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/spain/granada.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Granada"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Granada </span> Granada blends Moorish Alhambra beauty, Sierra Nevada views, cobbled streets, tapas bars, and vibrant plazas filled with authentic Andalusian culture and charm [2024]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

   <!-- Cordoba -->
    <div
      onclick="openModal('/Kf59_OP2QzY')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/spain/cordoba.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Wadi Rum"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Cordoba </span> Unforgettable Córdoba visit exploring winding old town streets, Mezquita-Catedral, Roman Bridge, Torre de la Calahorra, and historic city gates and atmosphere [2024]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>


   <!-- Seville -->
    <div
      onclick="openModal('/b4-V5A2VCts')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/spain/seville.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Wadi Rum"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Seville </span> Cinematic journey through Seville, Spain—iconic landmarks, rich history, stunning architecture, and vibrant culture captured in immersive 4K travel footage [2024]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

      </div>

</section>

<!-- VIDEO MODAL -->
<div
  id="videoModal"
  class="fixed inset-0 bg-black/80 hidden z-50 items-center justify-center backdrop-blur-sm"
>

  <div class="relative w-full max-w-4xl aspect-video transform transition-all duration-300 scale-95">

    <!-- Close button -->
    <button
      onclick="closeModal()"
      class="absolute -top-10 right-0 text-white text-2xl"
    >
      ✕
    </button>

    <!-- YouTube iframe -->
    <iframe
      id="videoFrame"
      class="w-full h-full rounded-xl"
      src=""
      frameborder="0"
      allow="autoplay; fullscreen"
      allowfullscreen
    ></iframe>

  </div>

</div>

</div>

<!-- ✅ ADD CSS HERE -->
<style>
/* Map is disabled */
.map-pin {
  display: none;
}
</style>


<script is:inline>
window.openModal = function(videoId) {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  frame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;

  modal.classList.remove('hidden');
  modal.classList.add('flex');

  document.body.style.overflow = 'hidden';

  requestAnimationFrame(() => {
    inner.classList.remove('scale-95');
    inner.classList.add('scale-100');
  });
};

window.closeModal = function() {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  // stop video completely
  frame.src = '';

  // reset animation
  inner.classList.add('scale-95');
  inner.classList.remove('scale-100');

  // hide modal
  modal.classList.add('hidden');
  modal.classList.remove('flex');

  // allow page scrolling again (important)
  document.body.style.overflow = 'auto';
};
</script>

</Layout>