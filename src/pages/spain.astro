---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Spain - Travel Chronicles Studio',
};
---

<Layout metadata={metadata}>

  <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">

    <div class="absolute inset-0">
      <img 
        src="/Images/spain/spain-hero.jpg" 
        class="w-full h-full object-cover"
        alt="Spain"
      />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Spain</h1>
      <p class="mt-4 text-lg opacity-90">
        A journey through Andalusian heritage, Moorish architecture, and vibrant cities
      </p>
    </div>

  </section>

  <!-- CONTENT -->
  <section class="max-w-4xl mx-auto px-6 py-16 space-y-20">

    <!-- ANDALUSIA OVERVIEW -->
    <div id="andalusia">
      <h2 class="text-3xl font-bold mb-6">Andalusia</h2>

      <p class="text-sm opacity-80 leading-relaxed mb-6">
        Andalusia is the cultural heart of southern Spain, shaped by centuries of Moorish influence,
        flamenco traditions, and stunning architecture across its historic cities.
      </p>
    </div>

    <!-- SEVILLE -->
    <div id="seville">
      <h2 class="text-3xl font-bold mb-6">Seville</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/seville.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Seville is home to the Alcázar, Gothic cathedrals, and lively plazas filled with orange trees and flamenco spirit.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- MALAGA -->
    <div id="malaga">
      <h2 class="text-3xl font-bold mb-6">Málaga</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/malaga.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Málaga blends coastal energy with history, from Picasso’s birthplace to its hilltop Alcazaba fortress.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- GRANADA -->
    <div id="granada">
      <h2 class="text-3xl font-bold mb-6">Granada</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/granada-alhambra.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Granada is defined by the Alhambra, a masterpiece of Moorish architecture overlooking the Sierra Nevada.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- CORDOBA -->
    <div id="cordoba">
      <h2 class="text-3xl font-bold mb-6">Córdoba</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/cordoba-mesquita.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Córdoba’s Mezquita is one of Europe’s most remarkable Islamic-Christian architectural transformations.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- MADRID -->
    <div id="madrid">
      <h2 class="text-3xl font-bold mb-6">Madrid</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/madrid.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Madrid is Spain’s cultural capital, home to the Prado Museum, Royal Palace, and grand boulevards.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- BARCELONA -->
    <div id="barcelona">
      <h2 class="text-3xl font-bold mb-6">Barcelona</h2>

      <div class="grid md:grid-cols-3 gap-6">

        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img src="/Images/spain/barcelona.jpg" class="w-full aspect-[16/9] object-cover" />
          <div class="p-4">
            <p class="text-sm opacity-80">
              Barcelona showcases Gaudí’s architecture, Mediterranean beaches, and the iconic Sagrada Família.
            </p>
          </div>
        </div>

      </div>
    </div>

  </section>

</Layout>