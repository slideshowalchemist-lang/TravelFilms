---
import Layout from '~/layouts/PageLayout.astro';
import saqqara from '~/assets/images/saqqara/mission_saqqara_thumbnail.png';
import karnakMut from '~/assets/images/Karnak/SEKHMET_Thumbnail.png';

const metadata = {
  title: 'Egypt - Travel Chronicles Studio',
};

// modal state (simple approach)
let activeVideo = '';
---

<Layout metadata={metadata}>




  <!-- HERO -->
