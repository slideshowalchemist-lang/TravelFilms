---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Greece - Travel Chronicles Studio',
};
---

<Layout metadata={metadata}>

 <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">

    <div class="absolute inset-0">
      <img src="/Images/greece/santorini_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Greece</h1>
      <p class="mt-4 text-lg opacity-90">Whitewashed villages, blue domes, dramatic cliffs, caldera views, sunsets, volcanic beaches, winding alleys, luxury stays, Aegean beauty, romantic atmosphere</p>
    </div>

  </section>

  <!-- CONTENT -->
  <section>Coming soon...</section>

</Layout>