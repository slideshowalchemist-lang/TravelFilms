---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Croatia - Travel Chronicles Studio',
};
---

<Layout metadata={metadata}>

 <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">

    <div class="absolute inset-0">
      <img src="/Images/croatia/croatia_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">Croatia</h1>
      <p class="mt-4 text-lg opacity-90">Adriatic coastline, historic towns, Dubrovnik walls, crystal waters, island hopping, medieval streets, scenic views, rich culture, sunshine, unforgettable seaside experiences</p>
    </div>

  </section>

  <!-- CONTENT -->
<!-- Croatia -->
<section id="highlights" class="max-w-4xl mx-auto px-6 pt-5 pb-0">

  <h2 class="text-2xl font-bold mb-6"></h2>

  <div class="grid md:grid-cols-3 gap-6">

    <!-- Croatia [Part 1]2018 -->
    <div
      onclick="openModal('/SZR7ou2UR-Y?')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/croatia/croatia_1_2018.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Croatia_Part 1"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Highlights [Part 1] </span> From vibrant Zagreb to coastal Split and historic Trogir, the journey unfolds through the cascading beauty of Plitvice Lakes National Park and the waterfalls of Krka National Park [2018].
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

   <!-- Croatia [Part 2]2018 -->
    <div
      onclick="openModal('/yHT7HuVhF3c?')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/croatia/croatia_2_2018.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="Croatia_Part 1"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Highlights [Part 2] </span> Sunlit Hvar, the glowing Blue Grotto, the sparkling Dalmatian Coast, and historic Dubrovnik capture the Adriatic at its most breathtaking [2018].
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>


      </div>
    </div>
</section>


<!-- VIDEO MODAL -->
<div
  id="videoModal"
  class="fixed inset-0 bg-black/80 hidden z-50 items-center justify-center backdrop-blur-sm"
>

  <div class="relative w-full max-w-4xl aspect-video transform transition-all duration-300 scale-95">

    <!-- Close button -->
    <button
      onclick="closeModal()"
      class="absolute -top-10 right-0 text-white text-2xl"
    >
      ✕
    </button>

    <!-- YouTube iframe -->
    <iframe
      id="videoFrame"
      class="w-full h-full rounded-xl"
      src=""
      frameborder="0"
      allow="autoplay; fullscreen"
      allowfullscreen
    ></iframe>

  </div>

</div>

</div>

<!-- ✅ ADD CSS HERE -->
<style>
/* Map is disabled */
.map-pin {
  display: none;
}
</style>


<script is:inline>
window.openModal = function(videoId) {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  frame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;

  modal.classList.remove('hidden');
  modal.classList.add('flex');

  document.body.style.overflow = 'hidden';

  requestAnimationFrame(() => {
    inner.classList.remove('scale-95');
    inner.classList.add('scale-100');
  });
};

window.closeModal = function() {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  // stop video completely
  frame.src = '';

  // reset animation
  inner.classList.add('scale-95');
  inner.classList.remove('scale-100');

  // hide modal
  modal.classList.add('hidden');
  modal.classList.remove('flex');

  // allow page scrolling again (important)
  document.body.style.overflow = 'auto';
};
</script>
</Layout>