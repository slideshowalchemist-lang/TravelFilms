---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'USA',
};
---

<Layout metadata={metadata}>

  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/Images/usa/usa_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">USA</h1>
      <p class="mt-4 text-lg opacity-90">
       Skyscrapers, energy, diversity, Broadway, yellow cabs, skyline, hustle, culture, landmarks, vibrancy, ambition, nightlife, icons, movement, opportunity
      </p>
    </div>
  </section>

   <!-- New York -->
<section id="highlights" class="max-w-4xl mx-auto px-6 pt-5 pb-0">

  <h2 class="text-2xl font-bold mb-6"></h2>

  <div class="grid md:grid-cols-3 gap-6">

    <!-- New York 2013 -->
    <div
      onclick="openModal('/EoQ-bvqP-yE')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/usa/newyork_2013_thumb.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="New York 2013"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> New York </span> Three weeks in New York [2013]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

        <!-- Los Angeles 2013 -->
    <div
      onclick="openModal('/cGu-XOB9tcI')"
      class="cursor-pointer group block overflow-hidden rounded-2xl"
    >
      <img
        src="/Images/usa/los_angeles.png"
      class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition duration-700"
        alt="New York 2013"
      />

      <div class="p-4">
        <p class="text-sm opacity-80 leading-relaxed">
         <span class="font-semibold text-base block mb-1"> Los Angeles </span> Sun, surf, skyline views, Dodgers excitement, Venice Beach vibes, Disneyland magic, Universal thrills, Rodeo Drive glamour, diverse culture [2013]
        </p>

        <span class="text-sm font-semibold underline mt-2 inline-block">
          ▶ Watch video
        </span>
      </div>
    </div>

      </div>
    </div>
</section>
<!-- VIDEO MODAL -->
<div
  id="videoModal"
  class="fixed inset-0 bg-black/80 hidden z-50 items-center justify-center backdrop-blur-sm"
>

  <div class="relative w-full max-w-4xl aspect-video transform transition-all duration-300 scale-95">

    <!-- Close button -->
    <button
      onclick="closeModal()"
      class="absolute -top-10 right-0 text-white text-2xl"
    >
      ✕
    </button>

    <!-- YouTube iframe -->
    <iframe
      id="videoFrame"
      class="w-full h-full rounded-xl"
      src=""
      frameborder="0"
      allow="autoplay; fullscreen"
      allowfullscreen
    ></iframe>

  </div>

</div>

</div>

<!-- ✅ ADD CSS HERE -->
<style>
/* Map is disabled */
.map-pin {
  display: none;
}
</style>


<script is:inline>
window.openModal = function(videoId) {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  frame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;

  modal.classList.remove('hidden');
  modal.classList.add('flex');

  document.body.style.overflow = 'hidden';

  requestAnimationFrame(() => {
    inner.classList.remove('scale-95');
    inner.classList.add('scale-100');
  });
};

window.closeModal = function() {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoFrame');
  const inner = modal.querySelector('div');

  // stop video completely
  frame.src = '';

  // reset animation
  inner.classList.add('scale-95');
  inner.classList.remove('scale-100');

  // hide modal
  modal.classList.add('hidden');
  modal.classList.remove('flex');

  // allow page scrolling again (important)
  document.body.style.overflow = 'auto';
};
</script>

</Layout>