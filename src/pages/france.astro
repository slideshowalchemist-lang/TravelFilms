---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'France',
};
---

<Layout metadata={metadata}>

  <section class="relative flex items-center justify-center min-h-[60vh] text-center px-6 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/Images/france/France_thumb.png" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-black/50"></div>
    </div>

    <div class="relative z-10 text-white">
      <h1 class="text-5xl md:text-6xl font-bold">France</h1>
      <p class="mt-4 text-lg opacity-90">
        Elegant, romantic, historic, artistic, vibrant, iconic, café-filled, stylish, cultural, timeless, lively, architectural, inspiring, sophisticated, unforgettable.
    </div>
  </section>

  <section>Coming soon...</section>

</Layout>